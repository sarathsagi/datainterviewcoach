generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Auth Models (NextAuth) ───────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  password      String?
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts        Account[]
  sessions        Session[]
  profile         Profile?
  studyPlans      StudyPlan[]
  dailyProgress   DailyProgress[]
  problemAttempts ProblemAttempt[]
  aiConversations AIConversation[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── App Models ───────────────────────────────────────────────

model Profile {
  id              String   @id @default(cuid())
  userId          String   @unique
  targetCompanies String[] @default([])
  interviewDate   DateTime?
  skillLevel      SkillLevel @default(BEGINNER)
  hoursPerDay     Float    @default(2)
  strengths       String[] @default([])
  weaknesses      String[] @default([])
  onboardingDone  Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum SkillLevel {
  BEGINNER
  INTERMEDIATE
  ADVANCED
}

model Topic {
  id          String        @id @default(cuid())
  name        String        @unique
  category    TopicCategory
  description String?
  order       Int           @default(0)

  problems     Problem[]
  studyPlanDays StudyPlanDay[]
}

enum TopicCategory {
  PYTHON
  SQL
  SYSTEM_DESIGN
  DATA_MODELING
  CULTURE_FIT
}

model Problem {
  id          String     @id @default(cuid())
  title       String
  difficulty  Difficulty
  topicId     String
  description String
  hints       String[]   @default([])
  solution    String?
  companyTags String[]   @default([])
  order       Int        @default(0)
  createdAt   DateTime   @default(now())

  topic           Topic            @relation(fields: [topicId], references: [id])
  studyPlanDays   StudyPlanDay[]
  problemAttempts ProblemAttempt[]
  aiConversations AIConversation[]
}

enum Difficulty {
  EASY
  MEDIUM
  HARD
}

model StudyPlan {
  id        String         @id @default(cuid())
  userId    String
  startDate DateTime
  endDate   DateTime
  totalDays Int
  status    StudyPlanStatus @default(ACTIVE)
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  user User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  days StudyPlanDay[]
}

enum StudyPlanStatus {
  ACTIVE
  COMPLETED
  PAUSED
}

model StudyPlanDay {
  id        String   @id @default(cuid())
  planId    String
  dayNumber Int
  date      DateTime
  topicId   String
  completed Boolean  @default(false)

  plan     StudyPlan @relation(fields: [planId], references: [id], onDelete: Cascade)
  topic    Topic     @relation(fields: [topicId], references: [id])
  problems Problem[]
}

model DailyProgress {
  id             String   @id @default(cuid())
  userId         String
  date           DateTime
  problemsSolved Int      @default(0)
  timeSpentMins  Int      @default(0)
  streak         Int      @default(0)
  createdAt      DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
}

model ProblemAttempt {
  id             String        @id @default(cuid())
  userId         String
  problemId      String
  startedAt      DateTime      @default(now())
  completedAt    DateTime?
  hintsUsed      Int           @default(0)
  aiInteractions Int           @default(0)
  status         AttemptStatus @default(IN_PROGRESS)

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  problem Problem @relation(fields: [problemId], references: [id])
}

enum AttemptStatus {
  IN_PROGRESS
  COMPLETED
  SKIPPED
}

model AIConversation {
  id        String   @id @default(cuid())
  userId    String
  problemId String?
  messages  Json     @default("[]")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  problem Problem? @relation(fields: [problemId], references: [id])
}
