generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Auth Models (NextAuth) ───────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  password      String?
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Stripe
  stripeCustomerId String? @unique

  accounts               Account[]
  sessions               Session[]
  profile                Profile?
  subscription           Subscription?
  studyPlans             StudyPlan[]
  dailyProgress          DailyProgress[]
  problemAttempts        ProblemAttempt[]
  aiConversations        AIConversation[]
  pathProgress           UserPathProgress[]
  moduleProgress         UserModuleProgress[]
  questionAttempts       UserQuestionAttempt[]
  pathQuestionAttempts   UserPathQuestionAttempt[]
  flashCardAttempts      UserFlashCardAttempt[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  email     String
  token     String   @unique
  expires   DateTime
  createdAt DateTime @default(now())

  @@unique([email, token])
}

model EmailVerificationToken {
  id        String   @id @default(cuid())
  email     String
  token     String   @unique
  expires   DateTime
  createdAt DateTime @default(now())

  @@unique([email, token])
}

// ─── Billing Models ──────────────────────────────────────────

model Subscription {
  id                   String             @id @default(cuid())
  userId               String             @unique
  stripeSubscriptionId String             @unique
  stripePriceId        String
  stripeCurrentPeriodEnd DateTime
  status               SubscriptionStatus @default(ACTIVE)
  plan                 SubscriptionPlan   @default(PRO_MONTHLY)
  cancelAtPeriodEnd    Boolean            @default(false)
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum SubscriptionStatus {
  ACTIVE
  CANCELED
  PAST_DUE
  UNPAID
  TRIALING
  INCOMPLETE
}

enum SubscriptionPlan {
  PRO_MONTHLY
  PRO_YEARLY
}

// ─── App Models ───────────────────────────────────────────────

model Profile {
  id              String   @id @default(cuid())
  userId          String   @unique
  targetCompanies String[] @default([])
  interviewDate   DateTime?
  skillLevel      SkillLevel @default(BEGINNER)
  hoursPerDay     Float    @default(2)
  strengths       String[] @default([])
  weaknesses      String[] @default([])
  onboardingDone  Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum SkillLevel {
  BEGINNER
  INTERMEDIATE
  ADVANCED
}

model Topic {
  id          String        @id @default(cuid())
  name        String        @unique
  category    TopicCategory
  description String?
  order       Int           @default(0)

  problems     Problem[]
  studyPlanDays StudyPlanDay[]
}

enum TopicCategory {
  PYTHON
  SQL
  SYSTEM_DESIGN
  DATA_MODELING
  CULTURE_FIT
}

// ─── Learning Content Models ──────────────────────────────────

model LearningPath {
  id          String          @id @default(cuid())
  slug        String          @unique
  title       String
  description String
  icon        String          @default("📚")
  category    ContentCategory
  level       SkillLevel
  order       Int             @default(0)
  isPublished Boolean         @default(true)
  createdAt   DateTime        @default(now())

  modules      LearningModule[]
  userProgress UserPathProgress[]
  questions    PathQuestion[]
}

model LearningModule {
  id              String   @id @default(cuid())
  pathId          String
  slug            String
  title           String
  description     String?
  content         String?
  mediumUrl       String?
  readTimeMinutes Int      @default(10)
  order           Int      @default(0)
  isPublished     Boolean  @default(true)
  createdAt       DateTime @default(now())

  path         LearningPath         @relation(fields: [pathId], references: [id], onDelete: Cascade)
  userProgress UserModuleProgress[]

  @@unique([pathId, slug])
}

model UserPathProgress {
  id          String    @id @default(cuid())
  userId      String
  pathId      String
  startedAt   DateTime  @default(now())
  completedAt DateTime?

  user User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  path LearningPath @relation(fields: [pathId], references: [id], onDelete: Cascade)

  @@unique([userId, pathId])
}

model UserModuleProgress {
  id          String    @id @default(cuid())
  userId      String
  moduleId    String
  completedAt DateTime  @default(now())

  user   User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  module LearningModule @relation(fields: [moduleId], references: [id], onDelete: Cascade)

  @@unique([userId, moduleId])
}

enum ContentCategory {
  DATA_MODELING
  CDC
  GCP
  SNOWFLAKE
  DATABRICKS
  CI_CD
  DATA_ARCHITECTURE
  SYSTEM_DESIGN
  AI_ENGINEERING
  OPEN_TABLE_FORMATS
  ESSENTIAL_SKILLS
}

// ─── Practice Question Models ─────────────────────────────────

model PracticeQuestion {
  id          String           @id @default(cuid())
  slug        String           @unique
  title       String
  category    PracticeCategory
  difficulty  Difficulty
  description String
  context     String?          // schema or setup code (markdown)
  hints       String[]         @default([])
  solution    String
  explanation String
  tags        String[]         @default([])
  order       Int              @default(0)
  isPublished Boolean          @default(true)
  createdAt   DateTime         @default(now())

  attempts UserQuestionAttempt[]
}

model PathQuestion {
  id          String   @id @default(cuid())
  pathId      String
  question    String
  options     Json     // string[]
  answer      Int      // index of correct option (0-based)
  explanation String
  order       Int      @default(0)

  path     LearningPath             @relation(fields: [pathId], references: [id], onDelete: Cascade)
  attempts UserPathQuestionAttempt[]
}

model UserQuestionAttempt {
  id         String         @id @default(cuid())
  userId     String
  questionId String
  status     QuestionStatus
  updatedAt  DateTime       @default(now()) @updatedAt

  user     User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  question PracticeQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([userId, questionId])
}

model UserPathQuestionAttempt {
  id         String   @id @default(cuid())
  userId     String
  questionId String
  selected   Int
  isCorrect  Boolean
  createdAt  DateTime @default(now())

  user     User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  question PathQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([userId, questionId])
}

enum PracticeCategory {
  SQL
  PYTHON
}

// ─── Flashcard Models ─────────────────────────────────────────

model FlashCard {
  id          String   @id @default(cuid())
  topic       String   // e.g. "Data Modeling", "SQL", "Streaming & CDC"
  topicSlug   String   // e.g. "data-modeling", "sql"
  front       String   // Concept / term / question
  back        String   // Definition / explanation
  order       Int      @default(0)
  isPublished Boolean  @default(true)
  createdAt   DateTime @default(now())

  attempts UserFlashCardAttempt[]
}

model UserFlashCardAttempt {
  id        String   @id @default(cuid())
  userId    String
  cardId    String
  known     Boolean  // true = "Got it", false = "Review Again"
  updatedAt DateTime @updatedAt

  user User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  card FlashCard @relation(fields: [cardId], references: [id], onDelete: Cascade)

  @@unique([userId, cardId])
}

enum QuestionStatus {
  SOLVED
  ATTEMPTED
  SKIPPED
}

model Problem {
  id          String     @id @default(cuid())
  title       String
  difficulty  Difficulty
  topicId     String
  description String
  hints       String[]   @default([])
  solution    String?
  companyTags String[]   @default([])
  order       Int        @default(0)
  createdAt   DateTime   @default(now())

  topic           Topic            @relation(fields: [topicId], references: [id])
  studyPlanDays   StudyPlanDay[]
  problemAttempts ProblemAttempt[]
  aiConversations AIConversation[]
}

enum Difficulty {
  EASY
  MEDIUM
  HARD
}

model StudyPlan {
  id        String         @id @default(cuid())
  userId    String
  startDate DateTime
  endDate   DateTime
  totalDays Int
  status    StudyPlanStatus @default(ACTIVE)
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  user User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  days StudyPlanDay[]
}

enum StudyPlanStatus {
  ACTIVE
  COMPLETED
  PAUSED
}

model StudyPlanDay {
  id        String   @id @default(cuid())
  planId    String
  dayNumber Int
  date      DateTime
  topicId   String
  completed Boolean  @default(false)

  plan     StudyPlan @relation(fields: [planId], references: [id], onDelete: Cascade)
  topic    Topic     @relation(fields: [topicId], references: [id])
  problems Problem[]
}

model DailyProgress {
  id             String   @id @default(cuid())
  userId         String
  date           DateTime
  problemsSolved Int      @default(0)
  timeSpentMins  Int      @default(0)
  streak         Int      @default(0)
  createdAt      DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
}

model ProblemAttempt {
  id             String        @id @default(cuid())
  userId         String
  problemId      String
  startedAt      DateTime      @default(now())
  completedAt    DateTime?
  hintsUsed      Int           @default(0)
  aiInteractions Int           @default(0)
  status         AttemptStatus @default(IN_PROGRESS)

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  problem Problem @relation(fields: [problemId], references: [id])
}

enum AttemptStatus {
  IN_PROGRESS
  COMPLETED
  SKIPPED
}

model AIConversation {
  id        String   @id @default(cuid())
  userId    String
  problemId String?
  messages  Json     @default("[]")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  problem Problem? @relation(fields: [problemId], references: [id])
}
